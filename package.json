{
  "name": "medmesh",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "capture:hardware": "powershell -ExecutionPolicy Bypass -File .\\scripts\\capture-hardware.ps1",
    "dev:peer-ui": "pnpm --filter @medmesh/peer-ui dev",
    "dev:peer-core": "pnpm --filter @medmesh/peer-core dev",
    "dev:mobile": "pnpm --filter @medmesh/mobile start",
    "doctor:live": "pnpm --filter @medmesh/peer-core exec tsx scripts/live-doctor.ts",
    "final:submission": "powershell -ExecutionPolicy Bypass -File .\\scripts\\final-submission-pass.ps1",
    "freeze:submission-assets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\freeze-submission-assets.ps1",
    "lint": "pnpm -r --if-present lint",
    "prepare:live": "pnpm --filter @medmesh/peer-core exec tsx scripts/prewarm-live.ts",
    "prepare:live:dry": "pnpm --filter @medmesh/peer-core exec tsx scripts/prewarm-live.ts --dry-run",
    "qualify:live-host": "powershell -ExecutionPolicy Bypass -File .\\scripts\\qualify-live-host.ps1",
    "qualify:live-host:dry": "powershell -ExecutionPolicy Bypass -File .\\scripts\\qualify-live-host.ps1 -DryRun",
    "submission:check": "powershell -ExecutionPolicy Bypass -File .\\scripts\\submission-check.ps1",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "validate:live": "powershell -ExecutionPolicy Bypass -File .\\scripts\\live-validate.ps1",
    "validate:mock": "powershell -ExecutionPolicy Bypass -File .\\scripts\\mock-smoke.ps1"
  },
  "dependencies": {
    "@qvac/sdk": "0.12.0",
    "bare-process": "^4.4.1",
    "require-asset": "1.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
