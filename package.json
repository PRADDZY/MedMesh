{
  "name": "medmesh",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "capture:hardware": "powershell -ExecutionPolicy Bypass -File .\\scripts\\capture-hardware.ps1",
    "dev:peer-ui": "pnpm --filter @medmesh/peer-ui dev",
    "dev:peer-core": "pnpm --filter @medmesh/peer-core dev",
    "dev:mobile": "pnpm --filter @medmesh/mobile start",
    "lint": "pnpm -r --if-present lint",
    "prepare:live": "pnpm --filter @medmesh/peer-core exec tsx scripts/prewarm-live.ts",
    "prepare:live:dry": "pnpm --filter @medmesh/peer-core exec tsx scripts/prewarm-live.ts --dry-run",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "validate:live": "powershell -ExecutionPolicy Bypass -File .\\scripts\\live-validate.ps1",
    "validate:mock": "powershell -ExecutionPolicy Bypass -File .\\scripts\\mock-smoke.ps1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
